# Copy to `.env` and fill in. `.env` is .gitignore'd.

# -----------------------------------------------------------------------------
# Polygon.io — PRIMARY V1 data source (as of 2026-04-23, replacing WRDS).
# -----------------------------------------------------------------------------
# Free-tier sign-up: https://polygon.io/dashboard/api-keys
# Free tier: 5 calls/min, 10 years history, delayed real-time (fine for V1 dev).
# $29/mo Stocks Starter recommended for bulk historical pulls (100 calls/min).
POLYGON_API_KEY=

# -----------------------------------------------------------------------------
# WRDS — DEPRECATED for V1. Rice Jones School denied the application 2026-04-23.
# Kept here as commented context in case access ever opens up later.
# -----------------------------------------------------------------------------
# WRDS_USERNAME=
# WRDS_PASSWORD=

# -----------------------------------------------------------------------------
# Sharadar SF1/SEP — paid fallback (~$300/mo). Documented in spec §7 but not
# wired up. Only populate if Polygon proves insufficient.
# -----------------------------------------------------------------------------
SHARADAR_API_KEY=

# -----------------------------------------------------------------------------
# Local storage roots (bind-mounted in Docker)
# -----------------------------------------------------------------------------
AEGIS_DATA_DIR=./data
AEGIS_LEDGER_PATH=./data/ledger.sqlite

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
AEGIS_LOG_LEVEL=INFO
AEGIS_LOG_FORMAT=json
